				              -: Windows Privilege Escalation Detection using Wazuh SIEM :-

<group name="windows,privilege_escalation,">

  <!-- Detect User Account Creation -->
  <rule id="100200" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4720</field>
    <description>Windows User Account Created</description>
    <group>
      windows,
      account_management,
      privilege_escalation,
    </group>
    <mitre>
      <id>T1136</id>
    </mitre>
  </rule>

  <!-- Detect User Added to Administrators Group -->
  <rule id="100201" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4732</field>
    <description>Possible Privilege Escalation - User Added to Administrators Group</description>
    <group>
      windows,
      privilege_escalation,
      attack,
    </group>
    <mitre>
      <id>T1078</id>
      <id>T1098</id>
    </mitre>
  </rule>

  <!-- Detect Special Privileges Assigned -->
  <rule id="100202" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4672</field>
    <description>Special Privileges Assigned to New Logon</description>
    <group>
      windows,
      authentication,
      privilege_escalation,
    </group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

</group>

										-: Port Scanning Detection in SOC Lab using Wazuh :-
Rule Name -> Port_Scanning_Detection.xml		
	
<group name="windows,sysmon,portscan,">

  <rule id="100500" level="12">
    <if_group>sysmon_event3</if_group>

    <frequency>15</frequency>
    <timeframe>60</timeframe>

    <same_source_ip />

    <description>
      Possible Port Scanning Activity Detected from $(win.eventdata.sourceIp)
    </description>

    <mitre>
      <id>T1046</id>
    </mitre>

    <group>
      attack.discovery,
      portscan,
      nmap
    </group>
  </rule>

</group>

